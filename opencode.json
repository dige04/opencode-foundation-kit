{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-hive"],
  "mcp": {
    "beads-village": {
      "type": "local",
      "command": ["npx", "beads-village"]
    },
    "tilth": {
      "type": "local",
      "command": ["tilth", "--mcp", "--edit"]
    },
    "linear": {
      "type": "local",
      "command": ["npx", "-y", "mcp-remote", "https://mcp.linear.app/mcp"]
    },
    "notebooklm": {
      "type": "local",
      "command": ["npx", "-y", "notebooklm-mcp@latest"]
    }
  }
}
