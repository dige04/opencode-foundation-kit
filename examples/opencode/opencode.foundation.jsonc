{
  "$schema": "https://opencode.ai/config.json",
  
  // Optional richer profile for teams using this public starter.
  // Keep the root `opencode.json` minimal and adapt from this file only when
  // you want more explicit agent shaping.
  "plugin": ["opencode-hive"],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "fetch": {
      "type": "local",
      "command": ["uvx", "mcp-server-fetch"]
    }
  },
  "agent": {
    "planner": {
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "patch": false
      },
      "permission": {
        "bash": {
          "git status": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "rg *": "allow",
          "bd *": "allow",
          "*": "deny"
        }
      }
    },
    "researcher": {
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "patch": false
      }
    },
    "docs-manager": {
      "temperature": 0.2,
      "permission": {
        "write": {
          "docs/**/*.md": "allow",
          "pods/**/*.md": "allow",
          "*.md": "allow",
          "*": "deny"
        }
      }
    },
    "integration": {
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "patch": false
      }
    },
    "reviewer": {
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "patch": false
      }
    }
  }
}
