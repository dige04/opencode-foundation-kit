{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-hive"],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "fetch": {
      "type": "local",
      "command": ["uvx", "mcp-server-fetch"]
    }
  },
  "agent": {
    "planner": {
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "patch": false
      }
    },
    "docs-manager": {
      "temperature": 0.2
    },
    "reviewer": {
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "patch": false
      }
    }
  }
}
