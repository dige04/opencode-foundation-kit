{
  "$schema": "https://opencode.ai/config.json",

  // Full native team-stack example.
  // This keeps the same OpenCode + Hive + Beads model, and adds the Beads
  // Village coordination layer natively in OpenCode.
  "plugin": ["opencode-hive"],

  "mcp": {
    "beads-village": {
      "type": "local",
      "command": ["npx", "beads-village"]
    },
    "linear": {
      "type": "local",
      "command": ["npx", "-y", "mcp-remote", "https://mcp.linear.app/mcp"]
    },
    "notebooklm": {
      "type": "local",
      "command": ["npx", "-y", "notebooklm-mcp@latest"]
    },
    "tilth": {
      "type": "local",
      "command": ["tilth", "--mcp", "--edit"]
    }
  },

  "agent": {
    "planner": {
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "patch": false
      },
      "permission": {
        "bash": {
          "git status": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "rg *": "allow",
          "bd *": "allow",
          "npx beads-village*": "allow",
          "tilth *": "allow",
          "*": "deny"
        }
      }
    },
    "researcher": {
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "patch": false
      }
    },
    "docs-manager": {
      "temperature": 0.2,
      "permission": {
        "write": {
          "docs/**/*.md": "allow",
          "pods/**/*.md": "allow",
          "*.md": "allow",
          "*": "deny"
        }
      }
    },
    "integration": {
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "patch": false
      }
    },
    "reviewer": {
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "patch": false
      }
    }
  }
}
